# PostgreSQL connection string (Docker Compose maps port 5433 → avoid conflict with local Postgres)
DATABASE_URL=postgresql://ecommerce:ecommerce123@127.0.0.1:5433/ecommerce

# HTTP port for the NestJS API
PORT=3000

# Optional: separate database for E2E tests (defaults to DATABASE_URL above)
# TEST_DATABASE_URL=postgresql://ecommerce:ecommerce123@127.0.0.1:5433/ecommerce

# Optional: OpenAI API key for LLM-powered AI agent
# Set LLM_MODE=openai to enable LLM features (default: deterministic)
# OPENAI_API_KEY=sk-...
# LLM_MODE=deterministic
