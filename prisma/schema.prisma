generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id        String       @id @default(uuid())
  status    OrderStatus  @default(PENDING)
  items     OrderItem[]
  aiLogs    AILog[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  quantity  Int
  unitPrice Float
}

enum AILogIntent {
  CANCEL_ORDER
  CHECK_STATUS
  GENERAL_HELP
  CREATE_ORDER
}

enum AILogTool {
  CANCEL_ORDER
}

model AILog {
  id                       String          @id @default(uuid())
  orderId                  String?
  order                    Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  intent                   AILogIntent
  model                    String
  tokensUsed               Int
  responseTimeMs           Int
  toolCalled               AILogTool?
  toolSuccess              Boolean?
  promptInjectionDetected  Boolean         @default(false)
  rawInput                 String?
  rawOutput                String?
  timestamp                DateTime        @default(now())
}
